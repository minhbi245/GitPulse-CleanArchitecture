// Staging.xcconfig
// iOS equivalent of Android productFlavors { create("stag") { ... } }
// Assigned to: "Staging Debug" and "Staging Release" configurations
//
// Android:
//   applicationIdSuffix = ".stag"
//   buildConfigField("String", "BASE_URL", "\"https://api.github.com\"")
//   buildConfigField("Boolean", "DB_ENCRYPTION_ENABLED", "true")

// App identity — suffix appended to base bundle ID in target settings
BUNDLE_ID_SUFFIX = .stag
APP_DISPLAY_NAME = GitPulse Staging

// API configuration
BASE_URL = https:/$()/api.github.com
BASE_DOMAIN = api.github.com

// Feature flags
DB_ENCRYPTION_ENABLED = YES
ENABLE_LOGGING = YES
