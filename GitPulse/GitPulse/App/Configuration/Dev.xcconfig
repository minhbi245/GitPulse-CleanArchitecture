// Dev.xcconfig
// iOS equivalent of Android productFlavors { create("dev") { ... } }
// Assigned to: "Dev Debug" and "Dev Release" configurations
//
// Android:
//   applicationIdSuffix = ".dev"
//   buildConfigField("String", "BASE_URL", "\"https://api.github.com\"")
//   buildConfigField("Boolean", "DB_ENCRYPTION_ENABLED", "false")

// App identity
PRODUCT_BUNDLE_IDENTIFIER = com.leonguyen.GitPulse.dev
APP_DISPLAY_NAME = GitPulse Dev

// API configuration
BASE_URL = https:/$()/api.github.com
BASE_DOMAIN = api.github.com

// Feature flags
DB_ENCRYPTION_ENABLED = NO
ENABLE_LOGGING = YES
